# SmartForge — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your real values.
# .env is git-ignored — NEVER commit your actual keys.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your credentials
#   python main.py
# ──────────────────────────────────────────────────────────────────────────────


# ── Gemini VLM (vehicle classification + Golden Frame verification) ────────────
# Free key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── Groq (report generation — fast LLM inference) ─────────────────────────────
# Free tier → https://console.groq.com
GROQ_API_KEY=


# ── SerpAPI (reverse image search fraud check) ────────────────────────────────
# 100 free searches/month → https://serpapi.com
SERPAPI_KEY=


# ── Winston AI (AI-generated image detection) ─────────────────────────────────
# 2 000 free credits/month → https://app.gowinston.ai
WINSTON_AI_KEY=


# ── MongoDB Atlas (primary database) ──────────────────────────────────────────
# Free M0 cluster → https://mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
# Leave empty to use automatic SQLite fallback (no Atlas required for dev).
SMARTFORGE_MONGO_URI=


# ── Model weight paths ─────────────────────────────────────────────────────────
# Paths are relative to the project root by default.
# Override here if your weights live elsewhere.
DAMAGE_MODEL_PATH=models/seg-best.pt
PART_MODEL_PATH=models/detect-best.pt
SAM_CHECKPOINT=models/sam_vit_b_01ec64.pth


# ── SQLite fallback path (used when SMARTFORGE_MONGO_URI is empty) ─────────────
SQLITE_PATH=data/smartforge_claims.db


# ── Agentic thresholds (optional — defaults match production values) ───────────
MAX_RETRIES=2
ESCALATION_THRESHOLD=70
CONFIDENCE_RECHECK_LIMIT=0.45
AUTO_APPROVE_THRESHOLD=85
HEALTH_SCORE_MIN=0.6


# ── Fraud detection ────────────────────────────────────────────────────────────
FRAUD_TRUST_THRESHOLD=40
FRAUD_GPS_MAX_DISTANCE_KM=50.0
PHASH_HAMMING_THRESHOLD=8
MAX_FRAUD_RETRIES=3
FRAUD_HASH_DB_PATH=data/fraud_hash_db.json

# Set to true to skip all Batch 1 fraud checks (useful for UI demos)
BYPASS_FRAUD=false


# ── Financial intelligence (Batch 4) ──────────────────────────────────────────
VEHICLE_VALUE=15000
TOTAL_LOSS_THRESHOLD=0.75
USD_TO_INR=83


# ── Gradio UI ─────────────────────────────────────────────────────────────────
GRADIO_SHARE=true
GRADIO_DEBUG=false
GRADIO_THEME=dark
USER_PORT=7860
AUDITOR_PORT=7861
