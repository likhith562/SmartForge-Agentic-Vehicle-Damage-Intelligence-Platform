# ── AI API Keys ───────────────────────────────────────────────────────────────
# Gemini 2.5 Flash VLM — free tier at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Groq Llama-3.3-70b — free tier at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (free tier at mongodb.com/atlas)
# Leave empty → automatic SQLite fallback at /content/smartforge_claims.db
SMARTFORGE_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# ── Optional Fraud Extensions ─────────────────────────────────────────────────
# SerpAPI reverse image search — 100 searches/month free at https://serpapi.com
SERPAPI_KEY=

# Winston AI image detection — 2000 credits/month free at https://app.gowinston.ai
WINSTON_AI_KEY=

# ── Model Paths ───────────────────────────────────────────────────────────────
# Custom YOLO models (ship with this repo inside models/)
DAMAGE_MODEL_PATH=data/models/seg-best.pt
PART_MODEL_PATH=data/models/detect-best.pt

# SAM ViT-B checkpoint — auto-downloaded ~375 MB from Meta CDN on first run
SAM_CHECKPOINT=data/models/sam_vit_b_01ec64.pth

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
SAHI_CONFIDENCE=0.3
SAHI_SLICE_SIZE=640
SAHI_OVERLAP=0.2
MAX_RETRIES=2

# ── Fraud Layer Thresholds ────────────────────────────────────────────────────
# Trust scores below FRAUD_TRUST_THRESHOLD → SUSPICIOUS_HIGH_RISK
FRAUD_TRUST_THRESHOLD=40
# Max GPS drift allowed between EXIF GPS and claimed loss location
FRAUD_GPS_MAX_DISTANCE_KM=50.0
# Hamming distance ≤ this value → near-duplicate pHash match
PHASH_HAMMING_THRESHOLD=8
# AI probability above this → flagged as AI-generated (Winston AI)
WINSTON_AI_THRESHOLD=0.70

# ── Decision Thresholds ───────────────────────────────────────────────────────
AUTO_APPROVE_THRESHOLD=85
ESCALATION_THRESHOLD=70

# ── Financial Intelligence ────────────────────────────────────────────────────
# Vehicle value in USD (used for Total Loss threshold calculation)
VEHICLE_VALUE=15000
# Repair cost > TOTAL_LOSS_THRESHOLD * vehicle value → TOTALED
TOTAL_LOSS_THRESHOLD=0.75
# INR conversion rate for display
USD_TO_INR=83

# ── Demo Controls ─────────────────────────────────────────────────────────────
# Set True to skip all Batch 1 fraud checks for demos
BYPASS_FRAUD=True
# 3-strike tolerance: case permanently closed after this many fraud failures
MAX_FRAUD_RETRIES=3

# ── Output Paths ──────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=/content/audit_log.json
CHECKPOINT_DUMP_PATH=/content/checkpoint_dump.json
GOLDEN_FRAME_CROP_DIR=/content/golden_crops
FRAUD_HASH_DB_PATH=/content/fraud_hash_db.json

# ── Golden Frame Verification (Batch 3) ───────────────────────────────────────
GOLDEN_FRAME_CROP_MARGIN=0.25
GOLDEN_FRAME_MIN_CROP_PX=128
GOLDEN_FRAME_CONFIDENCE_MIN=0.55
